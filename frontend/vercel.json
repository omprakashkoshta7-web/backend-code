{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "unsafe-none" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://backend-code-jrrs.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
